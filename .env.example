# ── Application ──
APP_NAME="Persona AI Studio"
APP_VERSION=1.0.0
DEBUG=false

# ── MongoDB ──
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=persona_ai_studio

# ── AI Provider ──
# Set at least one. Gemini is primary; Groq is the fallback.
# Valid Gemini keys start with "AIza"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq — currently the only working provider (compound-mini supports JSON mode)
GROQ_API_KEY=gsk_...
GROQ_MODEL=groq/compound-mini

# ── CORS ──
CORS_ORIGINS='["http://localhost:8000"]'
